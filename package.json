{
  "name": "pdf-parse-poc",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.20.0 <21"
  },
  "volta": {
    "node": "20.20.2"
  },
  "scripts": {
    "predev:server": "node scripts/check-node-version.mjs",
    "dev:server": "tsx watch src/server/main.ts",
    "dev:web": "vite",
    "dev": "concurrently -n server,web -c cyan,magenta \"npm run dev:server\" \"npm run dev:web\"",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "ocr:download-models": "node scripts/download-ocr-models.mjs",
    "ocr:download-v5-models": "OCR_MODEL_VARIANT=v5-server node scripts/download-ocr-models.mjs models/esearch-ocr-v5",
    "ocr:download-v5-mobile-models": "OCR_MODEL_VARIANT=v5-mobile node scripts/download-ocr-models.mjs models/esearch-ocr-v5-mobile",
    "ocr:check-env": "node scripts/check-ocr-env.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@napi-rs/canvas": "^1.0.0",
    "@opendataloader/pdf": "^1.10.1",
    "element-plus": "^2.8.4",
    "esearch-ocr": "^8.5.0",
    "fastify": "^4.28.1",
    "onnxruntime-node": "^1.26.0",
    "opencc": "^1.3.1",
    "p-limit": "^6.2.0",
    "pdfjs-dist": "^4.4.168",
    "sharp": "^0.34.5",
    "uuid": "^10.0.0",
    "vue": "^3.4.31"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "concurrently": "^8.2.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.1"
  }
}
